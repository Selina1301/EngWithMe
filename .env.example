# Database Configuration
DB_HOST=127.0.0.1
DB_NAME=engwithme_db
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# Application Mode
APP_ENV=local
APP_DEBUG=true

# Mail Configuration (Gmail SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_ENCRYPTION=tls
MAIL_USERNAME=your_gmail_username@gmail.com
MAIL_PASSWORD="your_app_password"
MAIL_FROM_ADDRESS=your_gmail_username@gmail.com
MAIL_FROM_NAME="EngWithMe Support"

# Google OAuth Configuration
GOOGLE_CLIENT_ID="your_google_client_id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your_google_client_secret"
GOOGLE_REDIRECT_URI="http://localhost/projects/Demo_Study_English/api/google_callback.php"

# Cloud Storage Configuration (Cloudinary Optional Fallback)
CLOUDINARY_CLOUD_NAME="your_cloudinary_cloud_name"
CLOUDINARY_UPLOAD_PRESET="your_cloudinary_unsigned_preset"
